<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GameHub.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:GameHub.UI.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
        x:Class="GameHub.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="GameHub"
        WindowStartupLocation="CenterScreen"
        Width="1050" Height="650"
        Background="#1b2838">

    <Window.DataTemplates>
        
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:RegisterViewModel}">
            <views:RegisterView/>
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:MainViewModel}">
            <views:MainView/>
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:CatalogViewModel}">
            <views:CatalogView/>
        </DataTemplate>
        
    </Window.DataTemplates>

    <ContentControl Content="{Binding CurrentPage}" />

</Window>