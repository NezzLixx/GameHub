<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GameHub.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="GameHub.UI.Views.GameDetailsView"
             x:DataType="vm:GameDetailsViewModel"
             Background="#1b2838">

    <Grid RowDefinitions="Auto, *">
        <Button Grid.Row="0" Content="◀ Назад до каталогу" 
                Command="{Binding GoBackCommand}" 
                Background="#2a475e" Foreground="White" Margin="20,15,0,0"/>

        <ScrollViewer Grid.Row="1" Margin="20">
            <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="250, *">
                
                <Border Grid.Row="0" Grid.Column="0" CornerRadius="8" ClipToBounds="True" Height="350" Width="230" VerticalAlignment="Top">
                    <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                </Border>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,15">
                        <TextBlock Text="Розробник: " Foreground="#626366" FontSize="16"/>
                        <Button Content="{Binding DeveloperName}" 
                                Command="{Binding GoToDeveloperCommand}"
                                Background="Transparent" Foreground="#66c0f4" Padding="0" BorderThickness="0" FontSize="16" Cursor="Hand"/>
                    </StackPanel>

                    <TextBlock Text="ПРО ЦЮ ГРУ" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,10,0,5"/>
                    <TextBlock Text="{Binding Description}" Foreground="#c7d5e0" FontSize="15" TextWrapping="Wrap" LineHeight="22"/>
                </StackPanel>

                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,40,0,0" 
                        Background="#171a21" Padding="20" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="НАПИСАТИ РЕЦЕНЗІЮ" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
        
                        <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto" Margin="0,0,0,10">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Ваша оцінка: " Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox ItemsSource="{Binding Ratings}" SelectedItem="{Binding SelectedRating}" Width="70" Background="#1b2838" Foreground="White"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AttachedFileStatus}" Foreground="#626366" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                                <Button Name="AttachFileBtn" Content="📎 Додати фото/GIF" Click="AttachFileBtn_Click" Background="#2a475e" Foreground="White"/>
                            </StackPanel>
                        </Grid>

                        <TextBox Text="{Binding NewReviewText, Mode=TwoWay}" Watermark="Поділіться своїми враженнями про гру..." 
                                 Height="80" TextWrapping="Wrap" AcceptsReturn="True" Background="#1b2838" Foreground="White" BorderBrush="#2a475e" Margin="0,0,0,15"/>
        
                        <Button Content="Опублікувати рецензію" Command="{Binding SubmitReviewCommand}" HorizontalAlignment="Right" Background="#a3cf06" Foreground="Black" FontWeight="Bold" Padding="20,10"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,30,0,0">
                    <TextBlock Text="РЕЦЕНЗІЇ КОРИСТУВАЧІВ" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                    
                    <ItemsControl ItemsSource="{Binding Reviews}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ReviewUiModel">
                                <Border Background="#12141a" Margin="0,0,0,12" Padding="15" CornerRadius="4" BorderBrush="#2a475e" BorderThickness="1">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Username}" FontWeight="Bold" Foreground="#66c0f4" FontSize="14"/>
                                                <TextBlock Text="{Binding Rating, StringFormat=' ({0}/5 ★)'}" Foreground="#a3cf06" FontWeight="Bold" FontSize="14"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Comment}" Foreground="#c7d5e0" FontSize="14" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        
                                        <Border Grid.Column="1" Margin="15,0,0,0" MaxHeight="100" MaxWidth="150" CornerRadius="4" ClipToBounds="True" VerticalAlignment="Center">
                                            <Image Source="{Binding AttachedImage}" Stretch="Uniform"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>