<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GameHub.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1050" d:DesignHeight="650"
             x:Class="GameHub.UI.Views.CatalogView"
             x:DataType="vm:CatalogViewModel">

    <Grid RowDefinitions="Auto, *, Auto">
        
        <StackPanel Grid.Row="0" Margin="20,15,20,10">
            <TextBlock Text="КАТАЛОГ ІГОР" FontSize="24" FontWeight="Bold" Foreground="#ffffff" Margin="0,0,0,12"/>
            
            <Grid ColumnDefinitions="*, Auto, Auto">
                <TextBox Grid.Column="0" Watermark="Пошук гри за назвою..." 
                         Text="{Binding SearchText, Mode=TwoWay}" 
                         HorizontalAlignment="Stretch" Margin="0,0,15,0"
                         Background="#1b2838" Foreground="White" BorderBrush="#2a475e"/>
                
                <ComboBox Grid.Column="1" ItemsSource="{Binding Genres}" 
                          SelectedItem="{Binding SelectedGenre, Mode=TwoWay}"
                          Width="180" Margin="0,0,15,0"
                          Background="#1b2838" Foreground="White" BorderBrush="#2a475e"/>
                
                <ComboBox Grid.Column="2" SelectedIndex="{Binding SelectedSortIndex, Mode=TwoWay}" 
                          Width="180" Background="#1b2838" Foreground="White" BorderBrush="#2a475e">
                    <ComboBoxItem Content="За замовчуванням"/>
                    <ComboBoxItem Content="Назва (А-Я)"/>
                    <ComboBoxItem Content="Назва (Я-А)"/>
                </ComboBox>
            </Grid>
        </StackPanel>

        <ListBox Grid.Row="1" 
                 ItemsSource="{Binding Games}" 
                 SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                 Background="Transparent" Margin="10,0">
            
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:GameUiModel">
                    <Border Margin="8" CornerRadius="6" ClipToBounds="True" Background="#171a21" Cursor="Hand"
                            VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                        <Grid ToolTip.Tip="{Binding Title}">
                            <Image Source="{Binding Cover}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
            <Button Content="◀ Назад" 
                    Command="{Binding PreviousPageAsync}" 
                    Background="#2a475e" Foreground="White" Padding="10,5" Margin="5"/>
            
            <TextBlock Text="{Binding CurrentPage, StringFormat='Сторінка {0}'}" 
                       VerticalAlignment="Center" Foreground="White" Margin="15,0"/>
            
            <Button Content="Вперед ▶" 
                    Command="{Binding NextPageAsync}" 
                    Background="#2a475e" Foreground="White" Padding="10,5" Margin="5"/>
        </StackPanel>
    </Grid>
</UserControl>