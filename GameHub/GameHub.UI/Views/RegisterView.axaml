<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GameHub.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="550"
             x:Class="GameHub.UI.Views.RegisterView"
             x:DataType="vm:RegisterViewModel"
             Background="#1b2838">

    <Border Background="#171a21" 
            CornerRadius="8" 
            Padding="30" 
            Width="350" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Center"
            BoxShadow="0 4 20 #000000">

        <StackPanel Spacing="12">
            
            <TextBlock Text="СТВОРЕННЯ АКАУНТА" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#ffffff" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <StackPanel Spacing="4">
                <TextBlock Text="ЕЛЕКТРОННА ПОШТА" FontSize="11" FontWeight="SemiBold" Foreground="#c7d5e0"/>
                <TextBox PlaceholderText="example@email.com" 
                         Text="{Binding Email, Mode=TwoWay}"
                         Background="#2a475e" Foreground="#ffffff" BorderThickness="0" CornerRadius="4" Padding="10,8"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="ІМ'Я КОРИСТУВАЧА (ЛОГІН)" FontSize="11" FontWeight="SemiBold" Foreground="#c7d5e0"/>
                <TextBox PlaceholderText="Gamer123" 
                         Text="{Binding Username, Mode=TwoWay}"
                         Background="#2a475e" Foreground="#ffffff" BorderThickness="0" CornerRadius="4" Padding="10,8"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="ПАРОЛЬ" FontSize="11" FontWeight="SemiBold" Foreground="#c7d5e0"/>
                <TextBox PlaceholderText="••••••••" PasswordChar="*"
                         Text="{Binding Password, Mode=TwoWay}"
                         Background="#2a475e" Foreground="#ffffff" BorderThickness="0" CornerRadius="4" Padding="10,8"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="ПІДТВЕРДЖЕННЯ ПАРОЛЯ" FontSize="11" FontWeight="SemiBold" Foreground="#c7d5e0"/>
                <TextBox PlaceholderText="••••••••" PasswordChar="*"
                         Text="{Binding ConfirmPassword, Mode=TwoWay}"
                         Background="#2a475e" Foreground="#ffffff" BorderThickness="0" CornerRadius="4" Padding="10,8"/>
            </StackPanel>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="#ff4d4d" FontSize="12" HorizontalAlignment="Center" TextWrapping="Wrap"/>

            <Button Content="Зареєструватися" 
                    Command="{Binding RegisterCommand}"
                    Background="#a3cf06" Foreground="#ffffff" FontWeight="Bold" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,12" CornerRadius="4" Cursor="Hand"/>

            <Button Content="Вже є акаунт? Увійти..." 
                    Command="{Binding GoToLoginCommand}"
                    Background="Transparent" Foreground="#66c0f4" FontSize="12" HorizontalAlignment="Center" Cursor="Hand" Margin="0,5,0,0"/>

        </StackPanel>
    </Border>
</UserControl>